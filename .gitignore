# ---------- Node / frontend ----------
node_modules/
dist/
dist-ssr/
*.local
.vite/
coverage/
.eslintcache

# ---------- Rust / Tauri ----------
# Build artifacts (Cargo)
src-tauri/target/
# Tauri-generated bundle / platform code that regenerates
src-tauri/gen/schemas/
# Platform-specific scaffolds that pull in secrets/keystores
src-tauri/gen/apple/
src-tauri/gen/android/
# Lock files for platform-specific dirs stay in version control intentionally

# ---------- Env / secrets ----------
.env
.env.*
\!.env.example
*.pem
*.key
*.keystore
*.jks

# ---------- Local data ----------
# Development SQLite databases, if they ever land in-repo by accident
*.sqlite
*.sqlite3
*.db
*.db-journal
*.db-wal
*.db-shm

# ---------- Logs ----------
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ---------- Editor / OS ----------
.vscode/*
\!.vscode/extensions.json
\!.vscode/settings.recommended.json
.idea/
*.sw?
*.suo
*.ntvs*
*.njsproj
*.sln
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# ---------- Misc ----------
*.tsbuildinfo
.cache/
.tmp/
.history/

# Session scratch — never commit
.test-sync
